PROGRAM TylerBug IS

  INSTRUCTION TurnRight IS
    turnleft
    turnleft
    turnleft
  END TurnRight

  INSTRUCTION TurnAround IS
    turnleft
    turnleft
  END TurnAround

BEGIN
  WHILE true DO
    IF next-is-enemy THEN
      infect
    ELSE
      IF next-is-empty THEN
        move
      ELSE
        turnleft
      END IF
    END IF
  END WHILE
END TylerBug
